              <Name>Text26</Name>
              <Page isRef="14" />
              <Parent isRef="55" />
              <Text>&lt;b&gt;Notes:&lt;/b&gt;

&lt;ul&gt;
	&lt;li&gt;
		Dues once paid are NON REFUNDABLE
	&lt;/li&gt;
	&lt;li&gt;
		Scholarship will be continued on the basis of 90% attendance.
	&lt;/li&gt;
	&lt;li&gt;
		Rs. 50/- will be charged in case of Re-Issuance of Challan.
	&lt;/li&gt;
	&lt;li&gt;
		Kinship, Special, Old Student Concession will be continued.
	&lt;/li&gt;
	&lt;li&gt;
		Student Concession will be continued on the basis of 80% Attendance.
	&lt;/li&gt;
&lt;/ul&gt;</Text>
              <TextBrush>Black</TextBrush>
              <TextOptions>,,,,WordWrap=True,A=0</TextOptions>
