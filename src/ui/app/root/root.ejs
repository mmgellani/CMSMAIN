<!doctype html>
<html lang="en">

<head>
    <meta http-equiv="cache-control" content="max-age=0" />
    <meta http-equiv="cache-control" content="no-cache" />
    <meta http-equiv="expires" content="0" />
    <meta http-equiv="expires" content="Tue, 01 Jan 1980 1:00:00 GMT" />
    <meta http-equiv="pragma" content="no-cache" />

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>CMS 360*</title>

    <link rel="shortcut icon" href="assets/favicon.ico" />
    <link rel="icon" type="image/png" href="assets/favicon.png" />
</head>

<body class="">
    <link type="text/css" href="/mount.css" rel="stylesheet">
    <!-- pre-load animation or text element -->
    <div class="loader-wrapper">
        <div>
            <div class="loader"></div>
            <div class="loader-status text-center" style="display:none;text-align: center;">
                <div class="loader-message" style="color: #fafafa;">Processing</div>
                <div class="loader-progress" style="color: #fafafa;"></div>
            </div>
        </div>
    </div>

    <!-- application bootstrapper code that triggers display of loader, then mounts application  -->
    <script type="text/javascript" src="/mount.js"></script>

    <!-- mounted element -->
    <div id="app" style="display:none;height: 100% !important;">
        <loader v-show="isLoading"></loader>
        <router-view></router-view>
    </div>

    <script>
        var assets = `<%=htmlWebpackPlugin.files.css%>,<%=htmlWebpackPlugin.files.js%>,
            /assets/Reports/stimulsoft.reports.js,
            /assets/Reports/stimulsoft.viewer.js,
            /assets/msal.min.js`;
        var onContentLoaded = function () {
            var handle = window.setInterval(function () {
                if (window.bootstrap !== undefined) {
                    window.clearInterval(handle);
                    assets = assets.split(',');
                    window.bootstrap.loadAssets(assets);					
                }							
            }, 200)						
        }
        document.addEventListener('DOMContentLoaded', onContentLoaded);
    </script>
</body>

</html>